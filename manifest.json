{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "version": "1.0",
  "default_locale": "ar",
  "description": "__MSG_appDesc__",
  "permissions": ["storage"],
  "icons": {
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://*.kick.com/*", "*://kick.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["*://*.kick.com/*", "*://kick.com/*"],
      "js": ["caster.js"],
      "world": "MAIN",
      "run_at": "document_idle"
    }
  ]
}
